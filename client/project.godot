[layer_names]

3d_physics/layer_1="ground"
3d_physics/layer_2="player"
3d_physics/layer_3="npc"
3d_physics/layer_4="world_object"
3d_physics/layer_5="projectile"

[rendering]

renderer/rendering_method="forward_plus"
anti_aliasing/quality/msaa_3d=1
environment/defaults/default_clear_color=Color(0.15, 0.17, 0.21, 1)
